# ============================================================
# Environment Configuration
# ============================================================
# Copy this file to ".env" and update the values if necessary.
#
# Linux/macOS:
#   cp .env.example .env
#
# Windows PowerShell:
#   Copy-Item .env.example .env
# ============================================================

# Neo4j Connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# Synthetic Dataset Configuration
NUM_CLIENTS=20
NUM_TRANSACTIONS=40
NUM_FRAUD_CYCLES=3
RANDOM_SEED=42