# NEO4J_USER=neo4j
# NEO4J_PASSWORD=<senha-do-console>

# ── Parâmetros do gerador ────────────────────────────────────────
NUM_CLIENTS=20
NUM_TRANSACTIONS=40
NUM_FRAUD_CYCLES=3
RANDOM_SEED=42
